# Secrets — never commit
.env
.env.*
!.env.example
*.key
.deploy/

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Build / packaging
build/
dist/
*.spec

# Runtime data — keep the folder layout (.gitkeep), ignore the contents
*.db
data/runtime/*
data/uploads/*
data/documents/*
!data/**/.gitkeep
