# Copy to ".env" and fill in ONE provider block. The app is OpenAI-compatible,
# so only these four LLM vars matter: LLM_API_KEY, LLM_BASE_URL, LLM_MODEL, LLM_MODELS.
# (For local/offline use, just run run_local.bat — it sets the Ollama block for you.)

# ================== Multi-user SaaS settings ==================
# APP_ENV: "development" (local) or "production" (deployed). In production set
# COOKIE_SECURE=true and serve over HTTPS.
APP_ENV=development
APP_NAME=GLM Studio

# DATABASE_URL: leave blank for a local SQLite file (dev). In production use a
# Postgres URL, e.g. Neon:  postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# Auth / sessions
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
ALLOW_REGISTRATION=true

# Per-user shared-key quota: messages each signed-in user may send per UTC day.
# The first account to register becomes the admin (unlimited).
DAILY_MESSAGE_QUOTA=25

# Document uploads (context-stuffing): max file size + max extracted characters.
MAX_UPLOAD_MB=10
MAX_DOC_CHARS=200000

# Abuse protection (in-memory rate limiting). Leave true in production.
RATE_LIMIT_ENABLED=true

# Optional error monitoring (leave blank to disable)
SENTRY_DSN=
# ==============================================================

# --- Cloudflare Workers AI (US cloud, free) · token: dash.cloudflare.com (Workers AI perm) ---
# Account ID goes in the URL. Many free models available — see run.bat / the picker.
LLM_API_KEY=your_cloudflare_api_token
LLM_BASE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1
LLM_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
LLM_MODELS=@cf/meta/llama-3.3-70b-instruct-fp8-fast,@cf/meta/llama-3.1-8b-instruct-fp8,@cf/openai/gpt-oss-20b,@cf/mistralai/mistral-small-3.1-24b-instruct,@cf/zai-org/glm-5.2

# --- Local Ollama (private, offline, free) · install: ollama.com · run_local.bat uses this ---
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2:3b
# LLM_MODELS=llama3.2:3b,llama3.2:1b

# --- Groq (US, free, no training, fastest) · key: https://console.groq.com/keys ---
# LLM_API_KEY=gsk_your_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,gemma2-9b-it

# --- Google Gemini (US, free; trains on free-tier data) · key: https://aistudio.google.com/apikey ---
# LLM_API_KEY=AIza_your_key_here
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash
# LLM_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# --- Mistral (EU / GDPR) · key: https://console.mistral.ai/api-keys ---
# LLM_API_KEY=your_key_here
# LLM_BASE_URL=https://api.mistral.ai/v1
# LLM_MODEL=mistral-small-latest
# LLM_MODELS=mistral-small-latest,mistral-medium-latest

# --- Z.ai / GLM (Chinese cloud, free) · key: https://z.ai/manage-apikey/apikey-list ---
# LLM_API_KEY=your_zai_key
# LLM_BASE_URL=https://api.z.ai/api/paas/v4
# LLM_MODEL=glm-4.7-flash
# LLM_MODELS=glm-4.7-flash,glm-4.5-flash

# --- NVIDIA Build / NIM (US, free credits) · key: https://build.nvidia.com ---
# LLM_API_KEY=nvapi-your_key_here
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=zai-org/glm-5.1
# LLM_MODELS=zai-org/glm-5.1,zai-org/glm-4.7
